# Shared secret for X-Agent-Auth header. The web app's
# AGENT_TRIAGE_SHARED_SECRET must match this value.
# Generate a real one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
AGENT_SHARED_SECRET=dev-local-shared-secret-change-me

# OpenRouter API key — get one at https://openrouter.ai/keys
# Without this, /v1/run returns a stub "hello world" response so the
# UI and tests still work without burning tokens.
OPENROUTER_API_KEY=

# Default model when the request doesn't specify one. Browse models at
# https://openrouter.ai/models. Vision-capable defaults are recommended
# since photo input arrives in POC-4.
AGENT_TRIAGE_MODEL=anthropic/claude-sonnet-4-6
