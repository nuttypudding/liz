# URL of the maintenance-triage agent (server-side only)
AGENT_TRIAGE_URL=http://localhost:8101

# Must match AGENT_SHARED_SECRET in agents/maintenance-triage/.env.local
# Server-side only — never exposed to the browser. Do not prefix with NEXT_PUBLIC_.
AGENT_TRIAGE_SHARED_SECRET=dev-local-shared-secret-change-me
